  "keyFeatures": [
    "JWT-free session login with role-based access (admin, mozo/waiter)",
    "Table reservation system with date/time conflict prevention",
    "Multi-step order management with transactional database writes",
    "Payment and checkout flow with sales record creation",
    "Admin dashboard metrics: daily sales KPIs, top products, waiter performance",
    "Waiter capacity enforcement (max 4 tables per waiter)",
    "MySQL connection pooling via mysql2 with environment-based configuration",
    "CORS-enabled for cross-origin frontend integration"
  ],
  "publicApiSurface": [
